generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// SQLite has no native enum support in Prisma; role/channel/severity/status
// are plain strings validated against @app/shared's enums at the app layer.

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("user")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  alerts       Alert[]
}

model Category {
  id     String     @id @default(cuid())
  code   String     @unique
  label  String
  alerts Alert[]
  events Event[]
}

model Alert {
  id            String         @id @default(cuid())
  userId        String
  categoryId    String
  channel       String
  isEnabled     Boolean        @default(true)
  createdAt     DateTime       @default(now())
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      Category       @relation(fields: [categoryId], references: [id])
  notifications Notification[]

  @@unique([userId, categoryId, channel])
  @@index([categoryId, channel, isEnabled])
}

model Event {
  id            String         @id @default(cuid())
  categoryId    String
  title         String
  description   String
  severity      String
  sourceName    String
  payload       String
  triggeredById String?
  createdAt     DateTime       @default(now())
  category      Category       @relation(fields: [categoryId], references: [id])
  notifications Notification[]
}

model Notification {
  id        String   @id @default(cuid())
  eventId   String
  alertId   String?
  userId    String
  channel   String
  status    String
  detail    String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id])
  alert     Alert?   @relation(fields: [alertId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventId])
}
