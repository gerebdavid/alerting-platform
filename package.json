{
  "name": "alerts-platform",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/web"
  ],
  "scripts": {
    "dev": "concurrently -n backend,web -c blue,green \"npm run dev -w @app/backend\" \"npm run dev -w @app/web\"",
    "db:migrate": "npm run db:migrate -w @app/backend",
    "db:generate": "npm run db:generate -w @app/backend",
    "db:seed": "npm run db:seed -w @app/backend"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
